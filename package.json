    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^2.1.9"
